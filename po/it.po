#: indicator.js:487
msgid "Error locking OTP secrets."
msgstr "Errore durante il blocco dei segreti OTP."

#: indicator.js:497
msgid "Failed to unlock OTP secrets."
msgstr "Impossibile sbloccare i segreti OTP."

#: indicator.js:500
msgid "Error unlocking OTP secrets."
msgstr "Errore durante lo sblocco dei segreti OTP."

#: indicator.js:553
msgid "Error retrieving OTP items."
msgstr "Errore durante il recupero degli elementi OTP."

#: indicator.js:589
