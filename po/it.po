#: prefs.js:59 indicator.js:253
msgid "Error"
msgstr "Errore"

#: prefs.js:184
msgid "Scan QR code."
msgstr "Scansiona il codice QR."

#: prefs.js:198
msgid "Failed to parse \"qrscan-cmd\" option."
msgstr "Impossibile analizzare l'opzione \"qrscan-cmd\"."

#: prefs.js:231
msgid "Paste either the \"otpauth://\" URI, or the QR code image."
msgstr "Incolla l'URI \"otpauth://\" o l'immagine del codice QR."

#: prefs.js:258
msgid "Failed to parse \"qrimage-cmd\" option."
msgstr "Impossibile analizzare l'opzione \"qrimage-cmd\"."

#: prefs.js:342
msgid "Type"
msgstr "Tipo"

#: prefs.js:343
msgid "Select between time-based or counter-based OTP."
msgstr "Selezionare tra OTP basato sul tempo o sul contatore."

#: prefs.js:350
msgid "Issuer"
msgstr "Emittente"

#: prefs.js:352
msgid ""
"The name of the organization (Google, Facebook, etc) that issued the OTP."
msgstr ""
"Il nome dell'organizzazione (Google, Facebook, ecc.) che ha emesso l'OTP."

#: prefs.js:358
msgid "Name"
msgstr "Nome"

#: prefs.js:365
msgid "Secret"
msgstr "Segreto"

#: prefs.js:367
msgid "The shared secret key."
msgstr "La chiave segreta condivisa."

#: prefs.js:372
msgid "How the secret key is encoded."
msgstr "Come viene codificata la chiave segreta."

#: prefs.js:379
msgid "Digits"
msgstr "Cifre"

#: prefs.js:383
msgid "How many digits in the code."
msgstr "Quante cifre nel codice."

#: prefs.js:389
msgid "Period"
msgstr "Periodo"

#: prefs.js:391
msgid "Time between code updates, in seconds."
msgstr "Tempo tra gli aggiornamenti del codice, in secondi."

#: prefs.js:401
msgid "Counter"
msgstr "Contatore"

#: prefs.js:402
msgid ""
"This counter must be synchronized with the server, and it increments every "
"time a code is generated."
msgstr ""
"Questo contatore deve essere sincronizzato con il server e viene "
"incrementato ogni volta che viene generato un codice."

#: prefs.js:418
msgid "Algorithm"
msgstr "Algoritmo"

#: prefs.js:422
msgid "The hash algorithm used to generate codes."
msgstr "L'algoritmo hash utilizzato per generare codici."

#: prefs.js:428 prefs.js:908 prefs.js:1458
msgid "_Cancel"
msgstr "A_nnulla"

#: prefs.js:430
msgid "_OK"
msgstr "_OK"

#: prefs.js:566
msgid "Copy code to clipboard."
msgstr "Copia il codice negli appunti."

#: prefs.js:583 prefs.js:628
msgid "Unlock"
msgstr "Sblocca"

#: prefs.js:650 indicator.js:37
msgid "OTP code copied to clipboard."
msgstr "Codice OTP copiato negli appunti."

#: prefs.js:675
msgid "QR code"
msgstr "QR Code"

#: prefs.js:696 myAlertDialog.js:62
msgid "_Close"
msgstr "_Chiudi"

#: prefs.js:723
msgid ""
"Move this secret up; hold down the SHIFT key to move to the top of the list."
msgstr ""
"Sposta questo segreto in alto; tenere premuto il tasto MAIUSC per spostarsi "
"in cima all'elenco."

#: prefs.js:724
msgid ""
"Move this secret down; hold down the SHIFT key to move to the bottom of the "
"list."
msgstr ""
"Sposta questo segreto verso il basso; tenere premuto il tasto MAIUSC per "
"spostarsi in fondo all'elenco."

#: prefs.js:807
msgid "_Edit..."
msgstr "_Modificare..."

#: prefs.js:810
msgid "_Copy to clipboard"
msgstr "_Copia negli appunti"

#: prefs.js:813
msgid "Export to _QR code..."
msgstr "Esporta nel codice _QR..."

#: prefs.js:816
msgid "_Remove"
msgstr "_Rimuovere"

#: prefs.js:864
msgid "Importing \"otpauth://\" URIs"
msgstr "Importazione degli URI \"otpauth://\""

#: prefs.js:885
msgid "Paste all \"otpauth://\" URIs you want to import, one per line."
msgstr ""
"Incolla tutti gli URI \"otpauth://\" che desideri importare, uno per riga."

#: prefs.js:910
msgid "_Import"
msgstr "_Importare"

#: prefs.js:981 indicator.js:371
msgid "Unlock OTP secrets..."
msgstr "Sblocca i segreti OTP..."

#: prefs.js:984 indicator.js:367
msgid "Lock OTP secrets"
msgstr "Blocca i segreti OTP"

#: prefs.js:1058
msgid "Secrets"
msgstr "Segreti"

#: prefs.js:1059
msgid "A list of all OTP secrets from the keyring."
msgstr "Un elenco di tutti i segreti OTP dal portachiavi."

#: prefs.js:1079
msgid "Add secret..."
msgstr "Aggiungi segreto..."

#: prefs.js:1088
msgid "Refresh secrets."
msgstr "Aggiorna i segreti."

#: prefs.js:1098
msgid "Import secrets..."
msgstr "Importa segreti..."

#: prefs.js:1107
msgid "Export all secrets to the clipboard."
msgstr "Esporta tutti i segreti negli appunti."

#: prefs.js:1164
msgid "Creating new OTP secret"
msgstr "Creazione di un nuovo segreto OTP"

#: prefs.js:1175
msgid "Created new secret."
msgstr "Creato un nuovo segreto."

#: prefs.js:1207
msgid "Imported secrets:"
msgstr "Segreti importati:"

#: prefs.js:1231
msgid "Copied all OTP secrets to clipboard."
msgstr "Copiato tutti i segreti OTP negli appunti."

#: prefs.js:1371
msgid "Editing OTP secret"
msgstr "Modifica del segreto OTP"

#: prefs.js:1396
msgid "Copied secret URI to clipboard."
msgstr "URI segreto copiato negli appunti."

#: prefs.js:1417
msgid "Failed to parse \"qrencode-cmd\" option."
msgstr "Impossibile analizzare l'opzione \"qrencode-cmd\"."

#: prefs.js:1458
msgid "_Delete"
msgstr "_Eliminare"

#: prefs.js:1461
msgid "Deleting OTP secret"
msgstr "Eliminazione del segreto OTP"

#: prefs.js:1462
msgid "Deleting secret:"
msgstr "Segreti importati:"

#: prefs.js:1473
msgid "Failed to remove secret. Is it locked?"
msgstr "Impossibile rimuovere il segreto. E' bloccato?"

#: prefs.js:1475
msgid "Deleted secret:"
msgstr "Segreto eliminato:"

#: prefs.js:1517
msgid "Revert option back to the default value."
msgstr "Ripristina l'opzione al valore predefinito."

#: prefs.js:1553
msgid "Options"
msgstr "Opzioni"

#: prefs.js:1559
msgid "QR generator"
msgstr "Generatore di codici QR"

#: prefs.js:1560
msgid ""
"This command must read text from standard input, and write an image to the "
"standard output."
msgstr ""
"Questo comando deve leggere il testo dall'input standard e scrivere "
"un'immagine sullo standard output."

#: prefs.js:1567
msgid "QR reader"
msgstr "Lettore QR"

#: prefs.js:1568
msgid ""
"This command must read an image from the standard input, and print the "
"decoded URI to the standard output."
msgstr ""
"Questo comando deve leggere un'immagine dallo standard input e stampare "
"l'URI decodificato sullo standard output."

#: prefs.js:1575
msgid "QR scanner"
msgstr "Scanner QR"

#: prefs.js:1576
msgid ""
"This command must capture an image from a camera, and print the decoded URI "
"to the standard output."
msgstr ""
"Questo comando deve acquisire un'immagine da una fotocamera e stampare l'URI "
"decodificato sull'output standard."

#: prefs.js:1581
msgid "Clipboard clear delay"
msgstr "Ritardo cancellazione appunti"

#: prefs.js:1582
msgid "Sensitive data is cleared from the clipboard after this many seconds."
msgstr ""
"I dati sensibili vengono cancellati dagli appunti dopo questo numero di "
"secondi."

#: prefs.js:1583
msgid ""
"When exporting sensitive data (\"otpauth://\" URIs) they will be cleared "
"from the clipboard after this time has passed. Authentication codes are not "
"cleared."
msgstr ""
"Quando si esportano dati sensibili (URI \"otpauth://\"), questi verranno "
"cancellati dagli appunti una volta trascorso questo tempo. I codici di "
"autenticazione non vengono cancellati."

#: base32.js:28
msgid "Invalid base32 input; missing padding."
msgstr "Input base32 non valido; imbottitura mancante."

#: base32.js:44
msgid "Invalid base32 character at position:"
msgstr "Carattere base32 non valido nella posizione:"

#: base32.js:51
msgid "Invalid padding."
msgstr "Imbottitura non valida."

