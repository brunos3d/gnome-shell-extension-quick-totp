#: prefs.js:65 indicator.js:225
msgid "Error"
msgstr "Erreur"

#: prefs.js:166
msgid "Scan QR code."
msgstr "Scannez le code QR."

#: prefs.js:177
msgid "Failed to parse \"qrscan-cmd\" option."
msgstr "Échec de l'analyse de l'option \"qrscan-cmd\"."

#: prefs.js:202
msgid "Paste either the \"otpauth://\" URI, or the QR code image."
msgstr "Collez soit l'URI \"otpauth://\" ou l'image du code QR."

#: prefs.js:227
msgid "Failed to parse \"qrimage-cmd\" option."
msgstr "Échec de l'analyse de l'option \"qrimage-cmd\"."

#: prefs.js:306
msgid "Type"
msgstr "Type"

#: prefs.js:307
msgid "Select between time-based or counter-based OTP."
msgstr "Choisissez entre un OTP basé sur le temps ou sur un compteur."

#: prefs.js:314
msgid "Issuer"
msgstr "Émetteur"

#: prefs.js:317
msgid ""
"The name of the organization (Google, Facebook, etc) that issued the OTP."
msgstr "Le nom de l'organisation (Google, Facebook, etc.) qui a délivré l'OTP."

#: prefs.js:324
msgid "Name"
msgstr "Nom"

#: prefs.js:331
msgid "Secret"
msgstr "Secrète"

#: prefs.js:333
msgid "The shared secret key."
msgstr "La clé secrète partagée."

#: prefs.js:338
msgid "How the secret key is encoded."
msgstr "Comment la clé secrète est codée."

#: prefs.js:345
msgid "Digits"
msgstr "Chiffres"

#: prefs.js:349
msgid "How many digits in the code."
msgstr "Combien de chiffres dans le code."

#: prefs.js:355
msgid "Period"
msgstr "Période"

#: prefs.js:357
msgid "Time between code updates, in seconds."
msgstr "Temps entre les mises à jour du code, en secondes."

#: prefs.js:367
msgid "Counter"
msgstr "Compteur"

#: prefs.js:369
msgid ""
"This counter must be synchronized with the server, and it increments every "
"time a code is generated."
msgstr ""
"Ce compteur doit être synchronisé avec le serveur et il s'incrémente à "
"chaque génération de code."

#: prefs.js:386
msgid "Algorithm"
msgstr "Algorithme"

#: prefs.js:390
msgid "The hash algorithm used to generate codes."
msgstr "L'algorithme de hachage utilisé pour générer des codes."

#: prefs.js:395 prefs.js:815 prefs.js:1282
msgid "_Cancel"
msgstr "A_nnuler"

#: prefs.js:397
msgid "_OK"
msgstr "_Valider"

#: prefs.js:513
msgid "Copy code to clipboard."
msgstr "Copiez le code dans le presse-papiers."

#: prefs.js:532 prefs.js:572
msgid "Unlock"
msgstr "Déverrouiller"

#: prefs.js:590 indicator.js:33
msgid "OTP code copied to clipboard."
msgstr "Code OTP copié dans le presse-papiers."

#: prefs.js:609
msgid "QR code"
msgstr "QR Code"

#: prefs.js:630 myAlertDialog.js:51
msgid "_Close"
msgstr "_Fermer"

#: prefs.js:653
msgid ""
"Move this secret up; hold down the SHIFT key to move to the top of the list."
msgstr ""
"Déplacez ce secret vers le haut ; maintenez la touche MAJ enfoncée pour "
"passer en haut de la liste."

#: prefs.js:656
msgid ""
"Move this secret down; hold down the SHIFT key to move to the bottom of the "
"list."
msgstr ""
"Déplacez ce secret vers le bas ; maintenez la touche MAJ enfoncée pour "
"passer au bas de la liste."

#: prefs.js:727
msgid "_Edit..."
msgstr "_Modifier..."

#: prefs.js:729
msgid "_Copy to clipboard"
msgstr "_Copier dans le presse-papier"

#: prefs.js:731
msgid "Export to _QR code..."
msgstr "Exporter vers le code _QR..."

#: prefs.js:733
msgid "_Remove"
msgstr "_Retirer"

#: prefs.js:773
msgid "Importing \"otpauth://\" URIs"
msgstr "Importation des URI \"otpauth://\""

#: prefs.js:794
msgid "Paste all \"otpauth://\" URIs you want to import, one per line."
msgstr ""
"Collez tous les URI \"otpauth://\" que vous souhaitez importer, un par ligne."

#: prefs.js:817
msgid "_Import"
msgstr "_Importer"

#: prefs.js:869 indicator.js:346
msgid "Unlock OTP secrets..."
msgstr "Déverrouillez les secrets d'OTP..."

#: prefs.js:872 indicator.js:340
msgid "Lock OTP secrets"
msgstr "Verrouiller les secrets OTP"

#: prefs.js:936
msgid "Secrets"
msgstr "Secrets"

#: prefs.js:937
msgid "A list of all OTP secrets from the keyring."
msgstr "Une liste de tous les secrets OTP du porte-clés."

#: prefs.js:957
msgid "Add secret..."
msgstr "Ajouter un secret..."

#: prefs.js:966
msgid "Refresh secrets."
msgstr "Actualisez les secrets."

#: prefs.js:976
msgid "Import secrets..."
msgstr "Importer des secrets..."

#: prefs.js:985
msgid "Export all secrets to the clipboard."
msgstr "Exportez tous les secrets dans le presse-papiers."

#: prefs.js:1031
msgid "Creating new OTP secret"
msgstr "Création d'un nouveau secret OTP"

#: prefs.js:1041
msgid "Created new secret."
msgstr "Création d'un nouveau secret."

#: prefs.js:1069
msgid "Imported secrets:"
msgstr "Secrets importés :"

#: prefs.js:1091
msgid "Copied all OTP secrets to clipboard."
msgstr "Copié tous les secrets OTP dans le presse-papiers."

#: prefs.js:1208
msgid "Editing OTP secret"
msgstr "Modification du secret OTP"

#: prefs.js:1228
msgid "Copied secret URI to clipboard."
msgstr "URI secret copié dans le presse-papiers."

#: prefs.js:1244
msgid "Failed to parse \"qrencode-cmd\" option."
msgstr "Échec de l'analyse de l'option \"qrencode-cmd\"."

#: prefs.js:1282
msgid "_Delete"
msgstr "_Supprimer"

#: prefs.js:1285
msgid "Deleting OTP secret"
msgstr "Suppression du secret OTP"

#: prefs.js:1286
msgid "Deleting secret:"
msgstr "Suppression du secret :"

#: prefs.js:1297
msgid "Failed to remove secret. Is it locked?"
msgstr "Échec de la suppression du secret. Est-ce verrouillé ?"

#: prefs.js:1299
msgid "Deleted secret:"
msgstr "Secret supprimé :"

#: prefs.js:1332
msgid "Revert option back to the default value."
msgstr "Rétablir l'option à la valeur par défaut."

#: prefs.js:1359
msgid "Options"
msgstr "Options"

#: prefs.js:1365
msgid "QR generator"
msgstr "Générateur de QR"

#: prefs.js:1367
msgid ""
"This command must read text from standard input, and write an image to the "
"standard output."
msgstr ""
"Cette commande doit lire le texte de l'entrée standard et écrire une image "
"sur la sortie standard."

#: prefs.js:1375
msgid "QR reader"
msgstr "Lecteur QR"

#: prefs.js:1377
msgid ""
"This command must read an image from the standard input, and print the "
"decoded URI to the standard output."
msgstr ""
"Cette commande doit lire une image à partir de l'entrée standard et imprimer "
"l'URI décodé sur la sortie standard."

#: prefs.js:1385
msgid "QR scanner"
msgstr "Scanner QR"

#: prefs.js:1387
msgid ""
"This command must capture an image from a camera, and print the decoded URI "
"to the standard output."
msgstr ""
"Cette commande doit capturer une image d'une caméra et imprimer l'URI décodé "
"sur la sortie standard."

#: prefs.js:1393
msgid "Clipboard clear delay"
msgstr "Délai d'effacement du presse-papiers"

#: prefs.js:1395
msgid "Sensitive data is cleared from the clipboard after this many seconds."
msgstr ""
"Les données sensibles sont effacées du presse-papiers après ce nombre de "
"secondes."

#: prefs.js:1398
msgid ""
"When exporting sensitive data (\"otpauth://\" URIs) they will be cleared "
"from the clipboard after this time has passed. Authentication codes are not "
"cleared."
msgstr ""
"Lors de l'exportation de données sensibles (URI \"otpauth://\"), elles "
"seront effacées du presse-papiers une fois ce délai écoulé. Les codes "
"d'authentification ne sont pas effacés."

#: base32.js:23
msgid "Invalid base32 input; missing padding."
msgstr "Entrée base32 invalide ; rembourrage manquant."

#: base32.js:39
msgid "Invalid base32 character at position:"
msgstr "Caractère base32 invalide à la position :"

#: base32.js:46
msgid "Invalid padding."
msgstr "Remplissage invalide."

