msgid "URI host should be \"hotp\""
msgstr "De uri-host dient ‘hotp’ te zijn"

#: otp.js:40
msgid "Invalid algorithm."
msgstr "Ongeldig algoritme."

#: otp.js:132
msgid "Failed to parse URI."
msgstr "De uri kan niet worden verwerkt."

#: otp.js:134
msgid "URI scheme should be \"otpauth://...\""
msgstr "Het uri-scherma dient te beginnen met ‘otpauth://…’"

#: otp.js:136
msgid "Unexpected port number in URI."
msgstr "Ongeldig poortnummer in uri."

#: totp.js:50
msgid "URI host should be \"totp\""
msgstr "De uri-host dient ‘totp’ te zijn"
