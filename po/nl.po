#: prefs.js:66 src/ui/indicator.js:225
msgid "Error"
msgstr "Foutmelding"

#: prefs.js:167
msgid "Scan QR code."
msgstr "Scan QR-code."

#: prefs.js:178
msgid "Failed to parse \"qrscan-cmd\" option."
msgstr "Kan de optie \"qrscan-cmd\" niet parseren."

#: prefs.js:203
msgid "Paste either the \"otpauth://\" URI, or the QR code image."
msgstr "Plak de URI \"otpauth://\" of de afbeelding van de QR-code."

#: prefs.js:228
msgid "Failed to parse \"qrimage-cmd\" option."
msgstr "Kan de optie \"qrimage-cmd\" niet parseren."

#: prefs.js:307
msgid "Type"
msgstr "Type"

#: prefs.js:308
msgid "Select between time-based or counter-based OTP."
msgstr ""
"Kies tussen een op tijd gebaseerd of een op tellers gebaseerd OTP-systeem."

#: prefs.js:315
msgid "Issuer"
msgstr "Verstrekt door"

#: prefs.js:318
msgid ""
"The name of the organization (Google, Facebook, etc) that issued the OTP."
msgstr ""
"De naam van de organisatie (Google, Facebook, etc.) die het otp verstrekt "
"heeft."

#: prefs.js:325
msgid "Name"
msgstr "Naam"

#: prefs.js:332
msgid "Secret"
msgstr "Geheim"

#: prefs.js:334
msgid "The shared secret key."
msgstr "De gedeelde geheime sleutel."

#: prefs.js:339
msgid "How the secret key is encoded."
msgstr "Hoe de geheime sleutel is geëncodeerd."

#: prefs.js:346
msgid "Digits"
msgstr "Aantal getallen"

#: prefs.js:350
msgid "How many digits in the code."
msgstr "Hoeveel getallen de code bevat."

#: prefs.js:356
msgid "Period"
msgstr "Periode"

#: prefs.js:358
msgid "Time between code updates, in seconds."
msgstr "De tijd tussen codebijwerkingen (in seconden)."

#: prefs.js:368
msgid "Counter"
msgstr "Teller"

#: prefs.js:370
msgid ""
"This counter must be synchronized with the server, and it increments every "
"time a code is generated."
msgstr ""
"Deze teller moet gesynchroniseerd worden met de server en wordt verhoogd "
"elke keer dat er een code wordt gegenereerd."

#: prefs.js:387
msgid "Algorithm"
msgstr "Algoritme"

#: prefs.js:391
msgid "The hash algorithm used to generate codes."
msgstr "Het controlesomalgoritme van de gegenereerde codes."

#: prefs.js:396 prefs.js:816 prefs.js:1283
msgid "_Cancel"
msgstr "_Annuleren"

#: prefs.js:398
msgid "_OK"
msgstr "_Oké"

#: prefs.js:514
msgid "Copy code to clipboard."
msgstr "Kopieer de code naar het klembord."

#: prefs.js:533 prefs.js:573
msgid "Unlock"
msgstr "Ontgrendelen"

#: prefs.js:591 src/ui/indicator.js:33
msgid "OTP code copied to clipboard."
msgstr "De code is gekopieerd naar het klembord."

#: prefs.js:610
msgid "QR code"
msgstr "QR-code"

#: prefs.js:631 src/ui/widgets/my-alert-dialog.js:51
msgid "_Close"
msgstr "_Sluiten"

#: prefs.js:654
msgid ""
"Move this secret up; hold down the SHIFT key to move to the top of the list."
msgstr ""
"Verplaats dit geheim naar boven; Houd de SHIFT-toets ingedrukt om naar de "
"bovenkant van de lijst te gaan."

#: prefs.js:657
msgid ""
"Move this secret down; hold down the SHIFT key to move to the bottom of the "
"list."
msgstr ""
"Verplaats dit geheim naar beneden; Houd de SHIFT-toets ingedrukt om naar het "
"einde van de lijst te gaan."

#: prefs.js:728
msgid "_Edit..."
msgstr "_Bewerking..."

#: prefs.js:730
msgid "_Copy to clipboard"
msgstr "_Kopieer naar klembord"

#: prefs.js:732
msgid "Export to _QR code..."
msgstr "Exporteren naar _QR-code..."

#: prefs.js:734
msgid "_Remove"
msgstr "_Verwijderen"

#: prefs.js:774
msgid "Importing \"otpauth://\" URIs"
msgstr "'otpauth://'-URI's importeren"

#: prefs.js:795
msgid "Paste all \"otpauth://\" URIs you want to import, one per line."
msgstr "Plak alle te importeren ‘otpauth://’-uri's, een per regel."

#: prefs.js:818
msgid "_Import"
msgstr "_Importeren"

#: prefs.js:870 src/ui/indicator.js:346
msgid "Unlock OTP secrets..."
msgstr "Otp-geheimen ontgrendelen..."

#: prefs.js:873 src/ui/indicator.js:340
msgid "Lock OTP secrets"
msgstr "Otp-geheimen vergrendelen"

#: prefs.js:937
msgid "Secrets"
msgstr "Geheimen"

#: prefs.js:938
msgid "A list of all OTP secrets from the keyring."
msgstr "Een lijst met alle OTP-geheimen van de sleutelbos."

#: prefs.js:958
msgid "Add secret..."
msgstr "Geheim toevoegen…"

#: prefs.js:967
msgid "Refresh secrets."
msgstr "Vernieuw geheimen."

#: prefs.js:977
msgid "Import secrets..."
msgstr "Geheimen importeren…"

#: prefs.js:986
msgid "Export all secrets to the clipboard."
msgstr "Exporteer alle geheimen naar het klembord."

#: prefs.js:1032
msgid "Creating new OTP secret"
msgstr "Een nieuw OTP-geheim aanmaken"

#: prefs.js:1042
msgid "Created new secret."
msgstr "Nieuw geheim gecreëerd."

#: prefs.js:1070
msgid "Imported secrets:"
msgstr "Geïmporteerde geheimen:"

#: prefs.js:1092
msgid "Copied all OTP secrets to clipboard."
msgstr "Alle otp-geheimen zijn gekopieerd naar het klembord."

#: prefs.js:1209
msgid "Editing OTP secret"
msgstr "OTP-geheim bewerken"

#: prefs.js:1229
msgid "Copied secret URI to clipboard."
msgstr "Geheime URI naar klembord gekopieerd."

#: prefs.js:1245
msgid "Failed to parse \"qrencode-cmd\" option."
msgstr "Kan de optie \"qrencode-cmd\" niet parseren."

#: prefs.js:1283
msgid "_Delete"
msgstr "Verwij_deren"

#: prefs.js:1286
msgid "Deleting OTP secret"
msgstr "OTP-geheim verwijderen"

#: prefs.js:1287
msgid "Deleting secret:"
msgstr "Geheim verwijderen:"

#: prefs.js:1298
msgid "Failed to remove secret. Is it locked?"
msgstr "Het geheim kan niet worden verwijderd. Is het geheim vergrendeld?"

#: prefs.js:1300
msgid "Deleted secret:"
msgstr "Verwijderd geheim:"

#: prefs.js:1333
msgid "Revert option back to the default value."
msgstr "Zet de optie terug naar de standaardwaarde."

#: prefs.js:1360
msgid "Options"
msgstr "Opties"

#: prefs.js:1366
msgid "QR generator"
msgstr "QR-generator"

#: prefs.js:1368
msgid ""
"This command must read text from standard input, and write an image to the "
"standard output."
msgstr ""
"Deze opdracht moet tekst uit de standaardinvoer lezen en een afbeelding naar "
"de standaarduitvoer schrijven."

#: prefs.js:1376
msgid "QR reader"
msgstr "QR-lezer"

#: prefs.js:1378
msgid ""
"This command must read an image from the standard input, and print the "
"decoded URI to the standard output."
msgstr ""
"Deze opdracht moet een afbeelding uit de standaardinvoer lezen en de "
"gedecodeerde URI naar de standaarduitvoer afdrukken."

#: prefs.js:1386
msgid "QR scanner"
msgstr "QR-scanner"

#: prefs.js:1388
msgid ""
"This command must capture an image from a camera, and print the decoded URI "
"to the standard output."
msgstr ""
"Met deze opdracht moet een afbeelding van een camera worden vastgelegd en de "
"gedecodeerde URI naar de standaarduitvoer worden afgedrukt."

#: prefs.js:1394
msgid "Clipboard clear delay"
msgstr "Klembord duidelijke vertraging"

#: prefs.js:1396
msgid "Sensitive data is cleared from the clipboard after this many seconds."
msgstr ""
"Gevoelige gegevens worden na zoveel seconden van het klembord verwijderd."

#: prefs.js:1399
msgid ""
"When exporting sensitive data (\"otpauth://\" URIs) they will be cleared "
"from the clipboard after this time has passed. Authentication codes are not "
"cleared."
msgstr ""
"Bij het exporteren van gevoelige gegevens (\"otpauth://\" URI's) worden deze "
"na het verstrijken van deze tijd van het klembord verwijderd. "
"Authenticatiecodes worden niet gewist."

