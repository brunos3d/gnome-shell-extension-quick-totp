msgid "Failed to lock OTP secrets."
msgstr "De otp-geheimen kunnen niet worden vergrendeld."

#: indicator.js:523
msgid "Error locking OTP secrets."
msgstr "De otp-geheimen kunnen niet worden vergrendeld."

#: indicator.js:535
msgid "Failed to unlock OTP secrets."
msgstr "De otp-geheimen kunnen niet worden ontgrendeld."

#: indicator.js:539
msgid "Error unlocking OTP secrets."
msgstr "De otp-geheimen kunnen niet worden ontgrendeld."

#: indicator.js:598
msgid "Error retrieving OTP items."
msgstr "De otp-items kunnen niet worden opgehaald."

#: indicator.js:644
#, fuzzy
msgid "No matching OTP secrets."
msgstr "De otp-geheimen kunnen niet worden vergrendeld."

#: indicator.js:765
msgid "Error copying the OTP authentication code."
msgstr "De otp-verificatiecode kan niet worden gekopieerd."

#: secretUtils.js:206
msgid "Failed to lookup secret."
msgstr "Het geheim kan niet worden opgevraagd."

#: secretUtils.js:246
msgid "Failed to retrieve secret."
msgstr "Het geheim kan niet worden opgehaald."

#: secretUtils.js:283 secretUtils.js:322 secretUtils.js:346
msgid "Failed to lookup item."
msgstr "Kan item niet opzoeken."

#: secretUtils.js:290 secretUtils.js:329
msgid "Failed to set label."
msgstr "Het label kan niet worden ingesteld."

#: secretUtils.js:297
msgid "Failed to set attributes."
msgstr "De eigenschappen kunnen niet worden ingesteld."

#: secretUtils.js:303
msgid "Failed to set secret."
