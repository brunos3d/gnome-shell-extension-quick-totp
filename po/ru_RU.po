#: prefs.js:66 src/ui/indicator.js:225
msgid "Error"
msgstr "Ошибка"

#: prefs.js:167
msgid "Scan QR code."
msgstr "Сканировать QR-код."

#: prefs.js:178
msgid "Failed to parse \"qrscan-cmd\" option."
msgstr "Не удалось разобрать параметр \"qrscan-cmd\"."

#: prefs.js:203
msgid "Paste either the \"otpauth://\" URI, or the QR code image."
msgstr "Вставьте либо URI \"otpauth://\", либо изображение QR-кода."

#: prefs.js:228
msgid "Failed to parse \"qrimage-cmd\" option."
msgstr "Не удалось разобрать параметр \"qrimage-cmd\"."

#: prefs.js:307
msgid "Type"
msgstr "Тип"

#: prefs.js:308
msgid "Select between time-based or counter-based OTP."
msgstr ""
"Выберите между одноразовым паролем, основанным на времени, или на счетчике."

#: prefs.js:315
msgid "Issuer"
msgstr "Эмитент"

#: prefs.js:318
msgid ""
"The name of the organization (Google, Facebook, etc) that issued the OTP."
msgstr "Название организации (Google, Facebook и т.д.), которая выдала OTP."

#: prefs.js:325
msgid "Name"
msgstr "Название"

#: prefs.js:332
msgid "Secret"
msgstr "Пароль"

#: prefs.js:334
msgid "The shared secret key."
msgstr "Поделиться секретным ключом."

#: prefs.js:339
msgid "How the secret key is encoded."
msgstr "Как кодируется секретный ключ."

#: prefs.js:346
msgid "Digits"
msgstr "Цифры"

#: prefs.js:350
msgid "How many digits in the code."
msgstr "Сколько цифр в коде."

#: prefs.js:356
msgid "Period"
msgstr "Период"

#: prefs.js:358
msgid "Time between code updates, in seconds."
msgstr "Время между обновлениями кода в секундах."

#: prefs.js:368
msgid "Counter"
msgstr "Счетчик"

#: prefs.js:370
msgid ""
"This counter must be synchronized with the server, and it increments every "
"time a code is generated."
msgstr ""
"Этот счетчик должен быть синхронизирован с сервером и увеличивается каждый "
"раз при генерации кода."

#: prefs.js:387
msgid "Algorithm"
msgstr "Алгоритм"

#: prefs.js:391
msgid "The hash algorithm used to generate codes."
msgstr "Хэш-алгоритм, используемый для генерации кодов."

#: prefs.js:396 prefs.js:816 prefs.js:1283
msgid "_Cancel"
msgstr "_Отмена"

#: prefs.js:398
msgid "_OK"
msgstr "_Ок"

#: prefs.js:514
msgid "Copy code to clipboard."
msgstr "Скопировать код в буфер обмена."

#: prefs.js:533 prefs.js:573
msgid "Unlock"
msgstr "Разблокировать"

#: prefs.js:591 src/ui/indicator.js:33
msgid "OTP code copied to clipboard."
msgstr "OTP-код, скопированный в буфер обмена."

#: prefs.js:610
msgid "QR code"
msgstr "QR код"

#: prefs.js:631 src/ui/widgets/my-alert-dialog.js:51
msgid "_Close"
msgstr "_Закрыть"

#: prefs.js:654
msgid ""
"Move this secret up; hold down the SHIFT key to move to the top of the list."
msgstr ""
"Переместить этот пароль вверх; удерживая нажатой клавишу SHIFT, переместите "
"в начало списка."

#: prefs.js:657
msgid ""
"Move this secret down; hold down the SHIFT key to move to the bottom of the "
"list."
msgstr ""
"Переместить этот пароль вниз; удерживая нажатой клавишу SHIFT, переместите в "
"конец списка."

#: prefs.js:728
msgid "_Edit..."
msgstr "_Редактировать..."

#: prefs.js:730
msgid "_Copy to clipboard"
msgstr "_Копировать в буфер обмена"

#: prefs.js:732
msgid "Export to _QR code..."
msgstr "Экспорт в _QR код..."

#: prefs.js:734
msgid "_Remove"
msgstr "_Удалить"

#: prefs.js:774
msgid "Importing \"otpauth://\" URIs"
msgstr "Импорт URI \"otpauth://\""

#: prefs.js:795
msgid "Paste all \"otpauth://\" URIs you want to import, one per line."
msgstr ""
"Вставьте все URI \"otpauth://\", которые вы хотите импортировать, по одному "
"на строку."

#: prefs.js:818
msgid "_Import"
msgstr "_Импортировать"

#: prefs.js:870 src/ui/indicator.js:346
msgid "Unlock OTP secrets..."
msgstr "Разблокировать пароли OTP..."

#: prefs.js:873 src/ui/indicator.js:340
msgid "Lock OTP secrets"
msgstr "Заблокировать пароли OTP"

#: prefs.js:937
msgid "Secrets"
msgstr "Пароли"

#: prefs.js:938
msgid "A list of all OTP secrets from the keyring."
msgstr "Список всех паролей OTP на связке ключей."

#: prefs.js:958
msgid "Add secret..."
msgstr "Добавить пароль..."

#: prefs.js:967
msgid "Refresh secrets."
msgstr "Обновить пароли."

#: prefs.js:977
msgid "Import secrets..."
msgstr "Импортировать пароли..."

#: prefs.js:986
msgid "Export all secrets to the clipboard."
msgstr "Экспортировать все пароли в буфер обмена."

#: prefs.js:1032
msgid "Creating new OTP secret"
msgstr "Создать новый OTP пароль"

#: prefs.js:1042
msgid "Created new secret."
msgstr "Создать новый пароль."

#: prefs.js:1070
msgid "Imported secrets:"
msgstr "Импортированные пароли:"

#: prefs.js:1092
msgid "Copied all OTP secrets to clipboard."
msgstr "Копировать все OTP пароли в буфер обмена."

#: prefs.js:1209
msgid "Editing OTP secret"
msgstr "Редактирование пароля OTP"

#: prefs.js:1229
msgid "Copied secret URI to clipboard."
msgstr "Копировать пароль URI в буфер обмена."

#: prefs.js:1245
msgid "Failed to parse \"qrencode-cmd\" option."
msgstr "Не удалось разобрать параметр \"qrencode-cmd\"."

#: prefs.js:1283
msgid "_Delete"
msgstr "_Удалить"

#: prefs.js:1286
msgid "Deleting OTP secret"
msgstr "Удалить пароль OTP"

#: prefs.js:1287
msgid "Deleting secret:"
msgstr "Удаление пароля:"

#: prefs.js:1298
msgid "Failed to remove secret. Is it locked?"
msgstr "Не удалось удалить пароль. Он заблокирован?"

#: prefs.js:1300
msgid "Deleted secret:"
msgstr "Удалённый пароль:"

#: prefs.js:1333
msgid "Revert option back to the default value."
msgstr "Вернуть параметр к значению по умолчанию."

#: prefs.js:1360
msgid "Options"
msgstr "Параметры"

#: prefs.js:1366
msgid "QR generator"
msgstr "Генератор QR"

#: prefs.js:1368
msgid ""
"This command must read text from standard input, and write an image to the "
"standard output."
msgstr ""
"Эта команда должна считывать текст из стандартного ввода и записывать "
"изображение в стандартный вывод."

#: prefs.js:1376
msgid "QR reader"
msgstr "Считыватель QR"

#: prefs.js:1378
msgid ""
"This command must read an image from the standard input, and print the "
"decoded URI to the standard output."
msgstr ""
"Эта команда должна считывать изображение из стандартного ввода и выводить "
"декодированный URI в стандартный вывод."

#: prefs.js:1386
msgid "QR scanner"
msgstr "Сканер QR"

#: prefs.js:1388
msgid ""
"This command must capture an image from a camera, and print the decoded URI "
"to the standard output."
msgstr ""
"Эта команда должна захватить изображение с камеры и вывести декодированный "
"URI на стандартный вывод."

#: prefs.js:1394
msgid "Clipboard clear delay"
msgstr "Задержка очистки буфера обмена"

#: prefs.js:1396
msgid "Sensitive data is cleared from the clipboard after this many seconds."
msgstr ""
"По истечении этого времени конфиденциальные данные удаляются из буфера "
"обмена."

#: prefs.js:1399
msgid ""
"When exporting sensitive data (\"otpauth://\" URIs) they will be cleared "
"from the clipboard after this time has passed. Authentication codes are not "
"cleared."
msgstr ""
"При экспорте конфиденциальных данных (URI \"otpauth://\") они будут удалены "
"из буфера обмена по истечении этого времени. Коды аутентификации не "
"очищаются."

