#: prefs.js:65 src/ui/indicator.js:225
msgid "Error"
msgstr "Erro"

#: prefs.js:166
msgid "Scan QR code."
msgstr "Digitalize código QR."

#: prefs.js:177
msgid "Failed to parse \"qrscan-cmd\" option."
msgstr "Falhou ao interpretar a opção \"qrscan-cmd\"."

#: prefs.js:202
msgid "Paste either the \"otpauth://\" URI, or the QR code image."
msgstr "Cole o URI \"otpauth://\" ou a imagem do código QR."

#: prefs.js:227
msgid "Failed to parse \"qrimage-cmd\" option."
msgstr "Falhou ao interpretar a opção \"qrimage-cmd\"."

#: prefs.js:306
msgid "Type"
msgstr "Tipo"

#: prefs.js:307
msgid "Select between time-based or counter-based OTP."
msgstr "Selecione entre OTP baseado em tempo ou baseado em contador."

#: prefs.js:314
msgid "Issuer"
msgstr "Emissor"

#: prefs.js:317
msgid ""
"The name of the organization (Google, Facebook, etc) that issued the OTP."
msgstr "O nome da organização (Google, Facebook, etc) que emitiu o OTP."

#: prefs.js:324
msgid "Name"
msgstr "Nome"

#: prefs.js:331
msgid "Secret"
msgstr "Segredo"

#: prefs.js:333
msgid "The shared secret key."
msgstr "A chave secreta compartilhada."

#: prefs.js:338
msgid "How the secret key is encoded."
msgstr "Como a chave secreta é codificada."

#: prefs.js:345
msgid "Digits"
msgstr "Dígitos"

#: prefs.js:349
msgid "How many digits in the code."
msgstr "Quantos dígitos no código."

#: prefs.js:355
msgid "Period"
msgstr "Período"

#: prefs.js:357
msgid "Time between code updates, in seconds."
msgstr "Tempo entre atualizações do código, em segundos."

#: prefs.js:367
msgid "Counter"
msgstr "Contador"

#: prefs.js:369
msgid ""
"This counter must be synchronized with the server, and it increments every "
"time a code is generated."
msgstr ""
"Este contador deve ser sincronizado com o servidor, e incrementa toda vez "
"que um código é gerado."

#: prefs.js:386
msgid "Algorithm"
msgstr "Algorítimo"

#: prefs.js:390
msgid "The hash algorithm used to generate codes."
msgstr "O algorítimo usado para gerar códigos."

#: prefs.js:395 prefs.js:815 prefs.js:1282
msgid "_Cancel"
msgstr "_Cancelar"

#: prefs.js:397
msgid "_OK"
msgstr "_OK"

#: prefs.js:513
msgid "Copy code to clipboard."
msgstr "Copiar código para a área de transferência."

#: prefs.js:532 prefs.js:572
msgid "Unlock"
msgstr "Desbloquear"

#: prefs.js:590 src/ui/indicator.js:33
msgid "OTP code copied to clipboard."
msgstr "Código OTP copiado para a área de transferência."

#: prefs.js:609
msgid "QR code"
msgstr "Código QR"

#: prefs.js:630 src/ui/widgets/my-alert-dialog.js:51
msgid "_Close"
msgstr "_Fechar"

#: prefs.js:653
msgid ""
"Move this secret up; hold down the SHIFT key to move to the top of the list."
msgstr ""
"Mova este segredo para cima; mantenha pressionada a tecla SHIFT para ir para "
"o topo da lista."

#: prefs.js:656
msgid ""
"Move this secret down; hold down the SHIFT key to move to the bottom of the "
"list."
msgstr ""
"Mova este segredo para baixo; mantenha pressionada a tecla SHIFT para ir "
"para o final da lista."

#: prefs.js:727
msgid "_Edit..."
msgstr "_Editar..."

#: prefs.js:729
msgid "_Copy to clipboard"
msgstr "_Copiar para área de transferência"

#: prefs.js:731
msgid "Export to _QR code..."
msgstr "Exportar para código _QR..."

#: prefs.js:733
msgid "_Remove"
msgstr "_Remover"

#: prefs.js:773
msgid "Importing \"otpauth://\" URIs"
msgstr "Importar URIs \"otpauth://\""

#: prefs.js:794
msgid "Paste all \"otpauth://\" URIs you want to import, one per line."
msgstr "Cole todas as URIs \"otpauth://\", uma por linha."

#: prefs.js:817
msgid "_Import"
msgstr "_Importar"

#: prefs.js:869 src/ui/indicator.js:346
msgid "Unlock OTP secrets..."
msgstr "Desbloquear segredos OTP..."

#: prefs.js:872 src/ui/indicator.js:340
msgid "Lock OTP secrets"
msgstr "Bloquear segredos OTP"

#: prefs.js:936
msgid "Secrets"
msgstr "Segredos"

#: prefs.js:937
msgid "A list of all OTP secrets from the keyring."
msgstr "Uma lista de todos os segredos OTP do chaveiro."

#: prefs.js:957
msgid "Add secret..."
msgstr "Adicionar segredo..."

#: prefs.js:966
msgid "Refresh secrets."
msgstr "Atualizar segredos."

#: prefs.js:976
msgid "Import secrets..."
msgstr "Importar segredos..."

#: prefs.js:985
msgid "Export all secrets to the clipboard."
msgstr "Exporte todos os segredos para a área de transferência."

#: prefs.js:1031
msgid "Creating new OTP secret"
msgstr "Criando novo segredo OTP"

#: prefs.js:1041
msgid "Created new secret."
msgstr "Criou novo segredo."

#: prefs.js:1069
msgid "Imported secrets:"
msgstr "Importou segredos:"

#: prefs.js:1091
msgid "Copied all OTP secrets to clipboard."
msgstr "Copiado todos os segredos OTP para a área de transferência."

#: prefs.js:1208
msgid "Editing OTP secret"
msgstr "Editando segredo OTP"

#: prefs.js:1228
msgid "Copied secret URI to clipboard."
msgstr "URI secreta copiada para a área de transferência."

#: prefs.js:1244
msgid "Failed to parse \"qrencode-cmd\" option."
msgstr "Falhou ao interpretar a opção \"qrencode-cmd\"."

#: prefs.js:1282
msgid "_Delete"
msgstr "_Apagar"

#: prefs.js:1285
msgid "Deleting OTP secret"
msgstr "Apagando segredo OTP"

#: prefs.js:1286
msgid "Deleting secret:"
msgstr "Apagando segredo:"

#: prefs.js:1297
msgid "Failed to remove secret. Is it locked?"
msgstr "Falha em remover o segredo. Está bloqueado?"

#: prefs.js:1299
msgid "Deleted secret:"
msgstr "Apagou segredo:"

#: prefs.js:1332
msgid "Revert option back to the default value."
msgstr "Reverter opção de volta para o valor padrão."

#: prefs.js:1359
msgid "Options"
msgstr "Opções"

#: prefs.js:1365
msgid "QR generator"
msgstr "Gerador QR"

#: prefs.js:1367
msgid ""
"This command must read text from standard input, and write an image to the "
"standard output."
msgstr ""
"Este comando deve ler texto da entrada padrão, e escrever uma imagem para a "
"saída padrão."

#: prefs.js:1375
msgid "QR reader"
msgstr "Leitor QR"

#: prefs.js:1377
msgid ""
"This command must read an image from the standard input, and print the "
"decoded URI to the standard output."
msgstr ""
"Este comando deve ler uma imagem da entrada padrão e imprimir o URI "
"decodificado na saída padrão."

#: prefs.js:1385
msgid "QR scanner"
msgstr "Digitalizador QR"

#: prefs.js:1387
msgid ""
"This command must capture an image from a camera, and print the decoded URI "
"to the standard output."
msgstr ""
"Este comando deve capturar uma imagem de uma câmera e imprimir o URI "
"decodificado na saída padrão."

#: prefs.js:1393
msgid "Clipboard clear delay"
msgstr "Atraso na limpeza da área de transferência"

#: prefs.js:1395
msgid "Sensitive data is cleared from the clipboard after this many seconds."
msgstr ""
"Os dados confidenciais são apagados da área de transferência após esses "
"segundos."

#: prefs.js:1398
msgid ""
"When exporting sensitive data (\"otpauth://\" URIs) they will be cleared "
"from the clipboard after this time has passed. Authentication codes are not "
"cleared."
msgstr ""
"Ao exportar dados confidenciais (URIs \"otpauth://\"), eles serão apagados "
"da área de transferência após esse período. Os códigos de autenticação não "
"são apagados."

