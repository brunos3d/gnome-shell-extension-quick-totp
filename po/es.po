#: prefs.js:65 indicator.js:225
msgid "Error"
msgstr "Error"

#: prefs.js:166
msgid "Scan QR code."
msgstr "Escanear código QR."

#: prefs.js:177
msgid "Failed to parse \"qrscan-cmd\" option."
msgstr "No se pudo analizar la opción \"qrscan-cmd\"."

#: prefs.js:202
msgid "Paste either the \"otpauth://\" URI, or the QR code image."
msgstr "Pegue el URI \"otpauth://\" o la imagen del código QR."

#: prefs.js:227
msgid "Failed to parse \"qrimage-cmd\" option."
msgstr "No se pudo analizar la opción \"qrimage-cmd\"."

#: prefs.js:306
msgid "Type"
msgstr "Tipo"

#: prefs.js:307
msgid "Select between time-based or counter-based OTP."
msgstr "Seleccione entre OTP basado en tiempo o basado en contador."

#: prefs.js:314
msgid "Issuer"
msgstr "Emisor"

#: prefs.js:317
msgid ""
"The name of the organization (Google, Facebook, etc) that issued the OTP."
msgstr ""
"El nombre de la organización (Google, Facebook, etc.) que emitió la OTP."

#: prefs.js:324
msgid "Name"
msgstr "Nombre"

#: prefs.js:331
msgid "Secret"
msgstr "Secreto"

#: prefs.js:333
msgid "The shared secret key."
msgstr "La clave secreta compartida."

#: prefs.js:338
msgid "How the secret key is encoded."
msgstr "Cómo se codifica la clave secreta."

#: prefs.js:345
msgid "Digits"
msgstr "Dígitos"

#: prefs.js:349
msgid "How many digits in the code."
msgstr "Cuántos dígitos tiene el código."

#: prefs.js:355
msgid "Period"
msgstr "Período"

#: prefs.js:357
msgid "Time between code updates, in seconds."
msgstr "Tiempo entre actualizaciones de código, en segundos."

#: prefs.js:367
msgid "Counter"
msgstr "Contador"

#: prefs.js:369
msgid ""
"This counter must be synchronized with the server, and it increments every "
"time a code is generated."
msgstr ""
"Este contador debe estar sincronizado con el servidor y se incrementa cada "
"vez que se genera un código."

#: prefs.js:386
msgid "Algorithm"
msgstr "Algoritmo"

#: prefs.js:390
msgid "The hash algorithm used to generate codes."
msgstr "El algoritmo hash utilizado para generar códigos."

#: prefs.js:395 prefs.js:815 prefs.js:1282
msgid "_Cancel"
msgstr "_Cancelar"

#: prefs.js:397
msgid "_OK"
msgstr "_Aceptar"

#: prefs.js:513
msgid "Copy code to clipboard."
msgstr "Copie el código al portapapeles."

#: prefs.js:532 prefs.js:572
msgid "Unlock"
msgstr "Desbloquear"

#: prefs.js:590 indicator.js:33
msgid "OTP code copied to clipboard."
msgstr "Código OTP copiado al portapapeles."

#: prefs.js:609
msgid "QR code"
msgstr "Código QR"

#: prefs.js:630 myAlertDialog.js:51
msgid "_Close"
msgstr "_Cerrar"

#: prefs.js:653
msgid ""
"Move this secret up; hold down the SHIFT key to move to the top of the list."
msgstr ""
"Mueve este secreto hacia arriba; mantenga presionada la tecla MAYÚS para "
"pasar al principio de la lista."

#: prefs.js:656
msgid ""
"Move this secret down; hold down the SHIFT key to move to the bottom of the "
"list."
msgstr ""
"Mueve este secreto hacia abajo; mantenga presionada la tecla MAYÚS para ir "
"al final de la lista."

#: prefs.js:727
msgid "_Edit..."
msgstr "_Editar..."

#: prefs.js:729
msgid "_Copy to clipboard"
msgstr "_Copiar al portapapeles"

#: prefs.js:731
msgid "Export to _QR code..."
msgstr "Exportar a código _QR..."

#: prefs.js:733
msgid "_Remove"
msgstr "_Remover"

#: prefs.js:773
msgid "Importing \"otpauth://\" URIs"
msgstr "Importación de URI \"otpauth://\""

#: prefs.js:794
msgid "Paste all \"otpauth://\" URIs you want to import, one per line."
msgstr "Pegue todos los URI \"otpauth://\" que desee importar, uno por línea."

#: prefs.js:817
msgid "_Import"
msgstr "_Importar"

#: prefs.js:869 indicator.js:346
msgid "Unlock OTP secrets..."
msgstr "Desbloquear secretos de OTP..."

#: prefs.js:872 indicator.js:340
msgid "Lock OTP secrets"
msgstr "Bloquear secretos de OTP"

#: prefs.js:936
msgid "Secrets"
msgstr "Secreto"

#: prefs.js:937
msgid "A list of all OTP secrets from the keyring."
msgstr "Una lista de todos los secretos OTP del llavero."

#: prefs.js:957
msgid "Add secret..."
msgstr "Añadir secreto..."

#: prefs.js:966
msgid "Refresh secrets."
msgstr "Actualizar secretos."

#: prefs.js:976
msgid "Import secrets..."
msgstr "Importar secretos..."

#: prefs.js:985
msgid "Export all secrets to the clipboard."
msgstr "Exporta todos los secretos al portapapeles."

#: prefs.js:1031
msgid "Creating new OTP secret"
msgstr "Creando nuevo secreto OTP"

#: prefs.js:1041
msgid "Created new secret."
msgstr "Creó un nuevo secreto."

#: prefs.js:1069
msgid "Imported secrets:"
msgstr "Secretos importados:"

#: prefs.js:1091
msgid "Copied all OTP secrets to clipboard."
msgstr "Copié todos los secretos de OTP al portapapeles."

#: prefs.js:1208
msgid "Editing OTP secret"
msgstr "Edición de secreto OTP"

#: prefs.js:1228
msgid "Copied secret URI to clipboard."
msgstr "Se copió el URI secreto al portapapeles."

#: prefs.js:1244
msgid "Failed to parse \"qrencode-cmd\" option."
msgstr "No se pudo analizar la opción \"qrencode-cmd\"."

#: prefs.js:1282
msgid "_Delete"
msgstr "_Eliminar"

#: prefs.js:1285
msgid "Deleting OTP secret"
msgstr "Eliminando el secreto OTP"

#: prefs.js:1286
msgid "Deleting secret:"
msgstr "Borrando secreto:"

#: prefs.js:1297
msgid "Failed to remove secret. Is it locked?"
msgstr "No se pudo eliminar el secreto. ¿Está bloqueado?"

#: prefs.js:1299
msgid "Deleted secret:"
msgstr "Secreto eliminado:"

#: prefs.js:1332
msgid "Revert option back to the default value."
msgstr "Revertir la opción al valor predeterminado."

#: prefs.js:1359
msgid "Options"
msgstr "Opciones"

#: prefs.js:1365
msgid "QR generator"
msgstr "Generador QR"

#: prefs.js:1367
msgid ""
"This command must read text from standard input, and write an image to the "
"standard output."
msgstr ""
"Este comando debe leer texto de la entrada estándar y escribir una imagen en "
"la salida estándar."

#: prefs.js:1375
msgid "QR reader"
msgstr "Lector de QR"

#: prefs.js:1377
msgid ""
"This command must read an image from the standard input, and print the "
"decoded URI to the standard output."
msgstr ""
"Este comando debe leer una imagen de la entrada estándar e imprimir el URI "
"decodificado en la salida estándar."

#: prefs.js:1385
msgid "QR scanner"
msgstr "Escáner QR"

#: prefs.js:1387
msgid ""
"This command must capture an image from a camera, and print the decoded URI "
"to the standard output."
msgstr ""
"Este comando debe capturar una imagen de una cámara e imprimir el URI "
"decodificado en la salida estándar."

#: prefs.js:1393
msgid "Clipboard clear delay"
msgstr "Retraso en borrar portapapeles"

#: prefs.js:1395
msgid "Sensitive data is cleared from the clipboard after this many seconds."
msgstr ""
"Los datos confidenciales se borran del portapapeles después de tantos "
"segundos."

#: prefs.js:1398
msgid ""
"When exporting sensitive data (\"otpauth://\" URIs) they will be cleared "
"from the clipboard after this time has passed. Authentication codes are not "
"cleared."
msgstr ""
"Al exportar datos confidenciales (\"otpauth://\" URI), se borrarán del "
"portapapeles una vez transcurrido este tiempo. Los códigos de autenticación "
"no se borran."

#: base32.js:23
msgid "Invalid base32 input; missing padding."
msgstr "Entrada base32 no válida; falta relleno."

#: base32.js:39
msgid "Invalid base32 character at position:"
msgstr "Carácter base32 no válido en la posición:"

#: base32.js:46
msgid "Invalid padding."
msgstr "Relleno no válido."

