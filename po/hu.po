#: prefs.js:66 src/ui/indicator.js:225
msgid "Error"
msgstr "Hiba"

#: prefs.js:167
msgid "Scan QR code."
msgstr "QR-kód beolvasása."

#: prefs.js:178
msgid "Failed to parse \"qrscan-cmd\" option."
msgstr "Nem sikerült feldolgozni a „qrscan-cmd” beállítást."

#: prefs.js:203
msgid "Paste either the \"otpauth://\" URI, or the QR code image."
msgstr "Illessze be az „otpauth://” URI-t vagy a QR-kód képét."

#: prefs.js:228
msgid "Failed to parse \"qrimage-cmd\" option."
msgstr "Nem sikerült feldolgozni a „qrimage-cmd” beállítást."

#: prefs.js:307
msgid "Type"
msgstr "Típus"

#: prefs.js:308
msgid "Select between time-based or counter-based OTP."
msgstr "Válasszon az időalapú vagy a számlálóalapú OTP között."

#: prefs.js:315
msgid "Issuer"
msgstr "Kibocsátó"

#: prefs.js:318
msgid ""
"The name of the organization (Google, Facebook, etc) that issued the OTP."
msgstr "Az OTP-t kibocsátó szervezet (Google, Facebook stb.) neve."

#: prefs.js:325
msgid "Name"
msgstr "Név"

#: prefs.js:332
msgid "Secret"
msgstr "Titok"

#: prefs.js:334
msgid "The shared secret key."
msgstr "A megosztott titkos kulcs."

#: prefs.js:339
msgid "How the secret key is encoded."
msgstr "A titkos kulcs kódolásának módja."

#: prefs.js:346
msgid "Digits"
msgstr "Számjegyek"

#: prefs.js:350
msgid "How many digits in the code."
msgstr "Hány számjegyes a kód."

#: prefs.js:356
msgid "Period"
msgstr "Időtartam"

#: prefs.js:358
msgid "Time between code updates, in seconds."
msgstr "A kódfrissítések közötti idő másodpercben."

#: prefs.js:368
msgid "Counter"
msgstr "Zseton"

#: prefs.js:370
msgid ""
"This counter must be synchronized with the server, and it increments every "
"time a code is generated."
msgstr ""
"Ezt a számlálót szinkronizálni kell a szerverrel, és minden kódgeneráláskor "
"növekszik."

#: prefs.js:387
msgid "Algorithm"
msgstr "Algoritmus"

#: prefs.js:391
msgid "The hash algorithm used to generate codes."
msgstr "A kódok generálásához használt hash-algoritmus."

#: prefs.js:396 prefs.js:816 prefs.js:1283
msgid "_Cancel"
msgstr "_Mégse"

#: prefs.js:398
msgid "_OK"
msgstr "_OK"

#: prefs.js:514
msgid "Copy code to clipboard."
msgstr "Kód másolása a vágólapra."

#: prefs.js:533 prefs.js:573
msgid "Unlock"
msgstr "Feloldás"

#: prefs.js:591 src/ui/indicator.js:33
msgid "OTP code copied to clipboard."
msgstr "Az OTP-kód a vágólapra másolva."

#: prefs.js:610
msgid "QR code"
msgstr "QR-kód"

#: prefs.js:631 src/ui/widgets/my-alert-dialog.js:51
msgid "_Close"
msgstr "_Bezárás"

#: prefs.js:654
msgid ""
"Move this secret up; hold down the SHIFT key to move to the top of the list."
msgstr ""
"Mozgassa ezt a titkot felfelé; tartsa lenyomva a SHIFT billentyűt, hogy a "
"lista tetejére lépjen."

#: prefs.js:657
msgid ""
"Move this secret down; hold down the SHIFT key to move to the bottom of the "
"list."
msgstr ""
"Mozgassa ezt a titkot lefelé; tartsa lenyomva a SHIFT billentyűt, hogy a "
"lista aljára lépjen."

#: prefs.js:728
msgid "_Edit..."
msgstr "_Szerkesztés…"

#: prefs.js:730
msgid "_Copy to clipboard"
msgstr "_Másolás a vágólapra"

#: prefs.js:732
msgid "Export to _QR code..."
msgstr "Exportálás QR-kódba…"

#: prefs.js:734
msgid "_Remove"
msgstr "_Eltávolítás"

#: prefs.js:774
msgid "Importing \"otpauth://\" URIs"
msgstr "„otpauth://” URI-k importálása"

#: prefs.js:795
msgid "Paste all \"otpauth://\" URIs you want to import, one per line."
msgstr ""
"Illessze be az összes importálandó „otpauth://” URI-t, soronként egyet."

#: prefs.js:818
msgid "_Import"
msgstr "_Importálás"

#: prefs.js:870 src/ui/indicator.js:346
msgid "Unlock OTP secrets..."
msgstr "OTP-titkok feloldása…"

#: prefs.js:873 src/ui/indicator.js:340
msgid "Lock OTP secrets"
msgstr "OTP-titkok zárolása"

#: prefs.js:937
msgid "Secrets"
msgstr "Titkok"

#: prefs.js:938
msgid "A list of all OTP secrets from the keyring."
msgstr "A kulcstartóból származó összes OTP-titok listája."

#: prefs.js:958
msgid "Add secret..."
msgstr "Titok hozzáadása…"

#: prefs.js:967
msgid "Refresh secrets."
msgstr "Titkok frissítése."

#: prefs.js:977
msgid "Import secrets..."
msgstr "Titkok importálása…"

#: prefs.js:986
msgid "Export all secrets to the clipboard."
msgstr "Összes titok exportálása a vágólapra."

#: prefs.js:1032
msgid "Creating new OTP secret"
msgstr "Új OTP-titok létrehozása"

#: prefs.js:1042
msgid "Created new secret."
msgstr "Új titok létrehozva."

#: prefs.js:1070
msgid "Imported secrets:"
msgstr "Titkok importálása:"

#: prefs.js:1092
msgid "Copied all OTP secrets to clipboard."
msgstr "Összes titok a vágólapra másolva."

#: prefs.js:1209
msgid "Editing OTP secret"
msgstr "OTP-titok szerkesztése"

#: prefs.js:1229
msgid "Copied secret URI to clipboard."
msgstr "Titok-URI a vágólapra másolva."

#: prefs.js:1245
msgid "Failed to parse \"qrencode-cmd\" option."
msgstr "Nem sikerült feldolgozni a „qrencode-cmd” beállítást."

#: prefs.js:1283
msgid "_Delete"
msgstr "_Törlés"

#: prefs.js:1286
msgid "Deleting OTP secret"
msgstr "OTP-titok törlése"

#: prefs.js:1287
msgid "Deleting secret:"
msgstr "Titok törlése:"

#: prefs.js:1298
msgid "Failed to remove secret. Is it locked?"
msgstr "Nem sikerült eltávolítani a titkot. Zárolva van?"

#: prefs.js:1300
msgid "Deleted secret:"
msgstr "Titok törölve:"

#: prefs.js:1333
msgid "Revert option back to the default value."
msgstr "A beállítás visszaállítása az alapértelmezett értékre."

#: prefs.js:1360
msgid "Options"
msgstr "Beállítások"

#: prefs.js:1366
msgid "QR generator"
msgstr "QR-kód-előállító"

#: prefs.js:1368
msgid ""
"This command must read text from standard input, and write an image to the "
"standard output."
msgstr ""
"Ennek a parancsnak szöveget kell olvasnia a szabványos bemenetről, és képet "
"kell írnia a szabványos kimenetre."

#: prefs.js:1376
msgid "QR reader"
msgstr "QR-kód-olvasó"

#: prefs.js:1378
msgid ""
"This command must read an image from the standard input, and print the "
"decoded URI to the standard output."
msgstr ""
"Ennek a parancsnak be kell olvasnia egy képet a szabványos bemenetről, és a "
"dekódolt URI-t ki kell írnia a szabványos kimenetre."

#: prefs.js:1386
msgid "QR scanner"
msgstr "QR-kód-beolvasó"

#: prefs.js:1388
msgid ""
"This command must capture an image from a camera, and print the decoded URI "
"to the standard output."
msgstr ""
"Ennek a parancsnak egy képet kell rögzítenie egy kamerárával, és a dekódolt "
"URI-t ki kell írnia a szabványos kimenetre."

#: prefs.js:1394
msgid "Clipboard clear delay"
msgstr "Vágólap törlésének késleltetése"

#: prefs.js:1396
msgid "Sensitive data is cleared from the clipboard after this many seconds."
msgstr "Az érzékeny adatok ennyi másodperc után törlődnek a vágólapról."

#: prefs.js:1399
msgid ""
"When exporting sensitive data (\"otpauth://\" URIs) they will be cleared "
"from the clipboard after this time has passed. Authentication codes are not "
"cleared."
msgstr ""
"Érzékeny adatok („otpauth://” URI-k) exportálásakor ezek az adatok az idő "
"letelte után törlődnek a vágólapról. A hitelesítési kódok nem törlődnek."

#: src/otp/hotp.js:67
msgid "URI host should be \"hotp\""
msgstr "Az URI-kiszolgálónak a következőnek kell lennie: „hotp”"

#: src/otp/otp.js:35
msgid "Invalid algorithm."
msgstr "Érvénytelen algoritmus."

#: src/otp/otp.js:103
msgid "Failed to parse URI."
msgstr "Nem sikerült elemezni az URI-t."

#: src/otp/otp.js:105
msgid "URI scheme should be \"otpauth://...\""
msgstr "Az URI-sémának a következőnek kell lennie: „otpauth://...”"

#: src/otp/otp.js:106
msgid "Unexpected port number in URI."
msgstr "Váratlan portszám az URI-ban."

#: src/otp/totp.js:43
msgid "URI host should be \"totp\""
msgstr "Az URI-kiszolgálónak a következőnek kell lennie: „totp”"

#: src/services/secret-utils.js:171
msgid "Failed to lookup secret."
msgstr "A titok keresése sikertelen."

#: src/services/secret-utils.js:203
msgid "Failed to retrieve secret."
msgstr "A titok lekérdezése sikertelen."

#: src/services/secret-utils.js:232 src/services/secret-utils.js:269
#: src/services/secret-utils.js:291
msgid "Failed to lookup item."
msgstr "Az elem keresése sikertelen."

#: src/services/secret-utils.js:239 src/services/secret-utils.js:275
msgid "Failed to set label."
msgstr "A címke beállítása sikertelen."

#: src/services/secret-utils.js:246
msgid "Failed to set attributes."
msgstr "Az attribútumok beállítása sikertelen."

#: src/services/secret-utils.js:252
msgid "Failed to set secret."
msgstr "Nem sikerült beállítani a titkot."

#: src/services/secret-utils.js:298
msgid "Failed to set counter."
msgstr "Nem sikerült beállítani a számlálót."

