#, fuzzy
msgid "No OTP secrets."
msgstr "OTP-titkok zárolása"

#: src/ui/indicator.js:473
#, fuzzy
msgid "Show OTP codes"
msgstr "OTP-titkok zárolása"

#: src/ui/indicator.js:474
msgid "Hide OTP codes"
msgstr ""

#: src/ui/indicator.js:484
msgid "Failed to lock OTP secrets."
msgstr "Nem sikerült zárolni az OTP-titkokat."

#: src/ui/indicator.js:487
msgid "Error locking OTP secrets."
msgstr "Hiba az OTP-titkok zárolásakor."

#: src/ui/indicator.js:497
msgid "Failed to unlock OTP secrets."
msgstr "Nem sikerült feloldani az OTP-titkokat."

#: src/ui/indicator.js:500
msgid "Error unlocking OTP secrets."
msgstr "Hiba az OTP-titkok feloldásakor."

#: src/ui/indicator.js:553
