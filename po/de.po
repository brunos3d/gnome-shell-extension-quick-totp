msgstr "Ungültiger Algorithmus."

#: otp.js:132
msgid "Failed to parse URI."
msgstr "URI konnte nicht analysiert werden."

#: otp.js:134
msgid "URI scheme should be \"otpauth://...\""
msgstr "Das URI-Schema sollte „otpauth://…“ sein."

#: otp.js:136
msgid "Unexpected port number in URI."
msgstr "Unerwartete Portnummer im URI."

