msgid "Failed to lookup secret."
msgstr "Das Geheimnis konnte nicht gesucht werden."

#: secretUtils.js:246
msgid "Failed to retrieve secret."
msgstr "Das Abrufen des Geheimnisses ist fehlgeschlagen."

#: secretUtils.js:283 secretUtils.js:322 secretUtils.js:346
msgid "Failed to lookup item."
msgstr "Das Element konnte nicht gesucht werden."

#: secretUtils.js:290 secretUtils.js:329
msgid "Failed to set label."
msgstr "Das Label konnte nicht festgelegt werden."

#: secretUtils.js:297
