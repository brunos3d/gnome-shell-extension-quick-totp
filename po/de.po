msgid "Failed to lock OTP secrets."
msgstr "OTP-Geheimnisse konnten nicht gesperrt werden."

#: indicator.js:487
msgid "Error locking OTP secrets."
msgstr "Fehler beim Sperren der OTP-Geheimnisse."

#: indicator.js:497
msgid "Failed to unlock OTP secrets."
msgstr "OTP-Geheimnisse konnten nicht entsperrt werden."

#: indicator.js:500
msgid "Error unlocking OTP secrets."
msgstr "Fehler beim Entsperren der OTP-Geheimnisse."

#: indicator.js:553
msgid "Error retrieving OTP items."
msgstr "Fehler beim Abrufen von OTP-Elementen."

#: indicator.js:589
#, fuzzy
