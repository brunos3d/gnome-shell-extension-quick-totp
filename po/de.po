msgstr "Fehler beim Sperren der OTP-Geheimnisse."

#: indicator.js:691
msgid "Error copying the OTP authentication code."
msgstr "Fehler beim Kopieren des OTP-Authentifizierungscodes."

#: secretUtils.js:171
msgid "Failed to lookup secret."
msgstr "Das Geheimnis konnte nicht gesucht werden."

#: secretUtils.js:203
msgid "Failed to retrieve secret."
msgstr "Das Abrufen des Geheimnisses ist fehlgeschlagen."

#: secretUtils.js:232 secretUtils.js:269 secretUtils.js:291
msgid "Failed to lookup item."
msgstr "Das Element konnte nicht gesucht werden."

#: secretUtils.js:239 secretUtils.js:275
msgid "Failed to set label."
msgstr "Das Label konnte nicht festgelegt werden."

#: secretUtils.js:246
msgid "Failed to set attributes."
msgstr "Attribute konnten nicht festgelegt werden."

#: secretUtils.js:252
msgid "Failed to set secret."
msgstr "Geheimnis konnte nicht festgelegt werden."

#: secretUtils.js:298
msgid "Failed to set counter."
msgstr "Fehler beim Einstellen des Zählers."

