#: prefs.js:59 indicator.js:253
msgid "Error"
msgstr "Fehler"

#: prefs.js:184
msgid "Scan QR code."
msgstr "QR-Code scannen."

#: prefs.js:198
msgid "Failed to parse \"qrscan-cmd\" option."
msgstr "Die Option „qrscan-cmd“ konnte nicht analysiert werden."

#: prefs.js:231
msgid "Paste either the \"otpauth://\" URI, or the QR code image."
msgstr "Fügen Sie entweder den URI „otpauth://“ oder das QR-Codebild ein."

#: prefs.js:258
msgid "Failed to parse \"qrimage-cmd\" option."
msgstr "Die Option „qrimage-cmd“ konnte nicht analysiert werden."

#: prefs.js:342
msgid "Type"
msgstr "Typ"

#: prefs.js:343
msgid "Select between time-based or counter-based OTP."
msgstr "Wählen Sie zwischen zeitbasiertem oder zählerbasiertem OTP."

#: prefs.js:350
msgid "Issuer"
msgstr "Aussteller"

#: prefs.js:352
msgid ""
"The name of the organization (Google, Facebook, etc) that issued the OTP."
msgstr ""
"Der Name der Organisation (Google, Facebook usw.), die das OTP herausgegeben "
"hat."

#: prefs.js:358
msgid "Name"
msgstr "Name"

#: prefs.js:365
msgid "Secret"
msgstr "Geheimnis"

#: prefs.js:367
msgid "The shared secret key."
msgstr "Der gemeinsame geheime Schlüssel."

#: prefs.js:372
msgid "How the secret key is encoded."
msgstr "Wie der geheime Schlüssel kodiert ist."

#: prefs.js:379
msgid "Digits"
msgstr "Ziffern"

#: prefs.js:383
msgid "How many digits in the code."
msgstr "Geben Sie an, wie viele Ziffern der Code enthält."

#: prefs.js:389
msgid "Period"
msgstr "Zeitraum"

#: prefs.js:391
msgid "Time between code updates, in seconds."
msgstr "Zeit zwischen Codeaktualisierungen in Sekunden."

#: prefs.js:401
msgid "Counter"
msgstr "Zähler"

#: prefs.js:402
msgid ""
"This counter must be synchronized with the server, and it increments every "
"time a code is generated."
msgstr ""
"Dieser Zähler muss mit dem Server synchronisiert werden und wird jedes Mal "
"inkrementiert, wenn ein Code generiert wird."

#: prefs.js:418
msgid "Algorithm"
msgstr "Algorithmus"

#: prefs.js:422
msgid "The hash algorithm used to generate codes."
msgstr "Der Hash-Algorithmus, der zum Generieren von Codes verwendet wird."

#: prefs.js:428 prefs.js:908 prefs.js:1458
msgid "_Cancel"
msgstr "_Abbrechen"

#: prefs.js:430
msgid "_OK"
msgstr "_OK"

#: prefs.js:566
msgid "Copy code to clipboard."
msgstr "Code in die Zwischenablage kopieren."

#: prefs.js:583 prefs.js:628
msgid "Unlock"
msgstr "Entsperren"

#: prefs.js:650 indicator.js:37
msgid "OTP code copied to clipboard."
msgstr "OTP-Code in die Zwischenablage kopiert."

#: prefs.js:675
msgid "QR code"
msgstr "QR-Code"

#: prefs.js:696 myAlertDialog.js:62
msgid "_Close"
msgstr "_Schließen"

#: prefs.js:723
msgid ""
"Move this secret up; hold down the SHIFT key to move to the top of the list."
msgstr ""
"Verschieben Sie dieses Geheimnis nach oben; Halten Sie die UMSCHALTTASTE "
"gedrückt, um an den Anfang der Liste zu gelangen."

#: prefs.js:724
msgid ""
"Move this secret down; hold down the SHIFT key to move to the bottom of the "
"list."
msgstr ""
"Verschiebe dieses Geheimnis nach unten; Halten Sie die UMSCHALTTASTE "
"gedrückt, um zum Ende der Liste zu gelangen."

#: prefs.js:807
msgid "_Edit..."
msgstr "_Bearbeiten..."

#: prefs.js:810
msgid "_Copy to clipboard"
msgstr "In die Zwischenablage _kopieren"

#: prefs.js:813
msgid "Export to _QR code..."
msgstr "Als _QR-Code exportieren..."

#: prefs.js:816
msgid "_Remove"
msgstr "_Entfernen"

#: prefs.js:864
msgid "Importing \"otpauth://\" URIs"
msgstr "Importieren von „otpauth://“-URIs"

#: prefs.js:885
msgid "Paste all \"otpauth://\" URIs you want to import, one per line."
msgstr ""
"Fügen Sie alle „otpauth://“-URIs ein, die Sie importieren möchten, einen pro "
"Zeile."

#: prefs.js:910
msgid "_Import"
msgstr "_Importieren"

#: prefs.js:981 indicator.js:371
msgid "Unlock OTP secrets..."
msgstr "Enthüllen Sie OTP-Geheimnisse..."

#: prefs.js:984 indicator.js:367
msgid "Lock OTP secrets"
msgstr "OTP-Geheimnisse sperren"

#: prefs.js:1058
msgid "Secrets"
msgstr "Geheimnisse"

#: prefs.js:1059
msgid "A list of all OTP secrets from the keyring."
msgstr "Eine Liste aller OTP-Geheimnisse aus dem Schlüsselbund."

#: prefs.js:1079
msgid "Add secret..."
msgstr "Geheimnis hinzufügen..."

#: prefs.js:1088
msgid "Refresh secrets."
msgstr "Geheimnisse auffrischen."

#: prefs.js:1098
msgid "Import secrets..."
msgstr "Geheimnisse importieren..."

#: prefs.js:1107
msgid "Export all secrets to the clipboard."
msgstr "Exportieren Sie alle Geheimnisse in die Zwischenablage."

#: prefs.js:1164
msgid "Creating new OTP secret"
msgstr "Neues OTP-Geheimnis erstellen"

#: prefs.js:1175
msgid "Created new secret."
msgstr "Neues Geheimnis erstellt."

#: prefs.js:1207
msgid "Imported secrets:"
msgstr "Importierte Geheimnisse:"

#: prefs.js:1231
msgid "Copied all OTP secrets to clipboard."
msgstr "Alle OTP-Geheimnisse in die Zwischenablage kopiert."

#: prefs.js:1371
msgid "Editing OTP secret"
msgstr "Bearbeiten des OTP-Geheimnisses"

#: prefs.js:1396
msgid "Copied secret URI to clipboard."
msgstr "Geheimer URI in die Zwischenablage kopiert."

#: prefs.js:1417
msgid "Failed to parse \"qrencode-cmd\" option."
msgstr "Die Option „qrencode-cmd“ konnte nicht analysiert werden."

#: prefs.js:1458
msgid "_Delete"
msgstr "_Löschen"

#: prefs.js:1461
msgid "Deleting OTP secret"
msgstr "OTP-Geheimnis wird gelöscht"

#: prefs.js:1462
msgid "Deleting secret:"
msgstr "Geheimnis löschen:"

#: prefs.js:1473
msgid "Failed to remove secret. Is it locked?"
msgstr "Geheimnis konnte nicht entfernt werden. Ist es verschlossen?"

#: prefs.js:1475
msgid "Deleted secret:"
msgstr "Gelöschtes Geheimnis:"

#: prefs.js:1517
msgid "Revert option back to the default value."
msgstr "Setzen Sie die Option auf den Standardwert zurück."

#: prefs.js:1553
msgid "Options"
msgstr "Optionen"

#: prefs.js:1559
msgid "QR generator"
msgstr "QR-Generator"

#: prefs.js:1560
msgid ""
"This command must read text from standard input, and write an image to the "
"standard output."
msgstr ""
"Dieser Befehl muss Text aus der Standardeingabe lesen und ein Bild in die "
"Standardausgabe schreiben."

#: prefs.js:1567
msgid "QR reader"
msgstr "QR-Reader"

#: prefs.js:1568
msgid ""
"This command must read an image from the standard input, and print the "
"decoded URI to the standard output."
msgstr ""
"Dieser Befehl muss ein Bild aus der Standardeingabe lesen und den "
"dekodierten URI auf der Standardausgabe ausgeben."

#: prefs.js:1575
msgid "QR scanner"
msgstr "QR-Scanner"

#: prefs.js:1576
msgid ""
"This command must capture an image from a camera, and print the decoded URI "
"to the standard output."
msgstr ""
"Dieser Befehl muss ein Bild von einer Kamera erfassen und den dekodierten "
"URI in der Standardausgabe ausgeben."

#: prefs.js:1581
msgid "Clipboard clear delay"
msgstr "Verzögerung beim Löschen der Zwischenablage"

#: prefs.js:1582
msgid "Sensitive data is cleared from the clipboard after this many seconds."
msgstr ""
"Nach dieser Anzahl von Sekunden werden vertrauliche Daten aus der "
"Zwischenablage gelöscht."

#: prefs.js:1583
msgid ""
"When exporting sensitive data (\"otpauth://\" URIs) they will be cleared "
"from the clipboard after this time has passed. Authentication codes are not "
"cleared."
msgstr ""
"Beim Export sensibler Daten („otpauth://“-URIs) werden diese nach Ablauf "
"dieser Zeit aus der Zwischenablage gelöscht. Authentifizierungscodes werden "
"nicht gelöscht."

#: base32.js:28
msgid "Invalid base32 input; missing padding."
msgstr "Ungültige Base32-Eingabe; fehlende Polsterung."

#: base32.js:44
msgid "Invalid base32 character at position:"
msgstr "Ungültiges Base32-Zeichen an Position:"

#: base32.js:51
msgid "Invalid padding."
msgstr "Ungültige Polsterung."

